// basically remove the rightmost set bit(1)
//removes it in each iteration

class Solution {
    public int hammingWeight(int n) 
    {
        int count=0;
        while(n>0)
        {
            n=n&(n-1);
            count++;
        }
        return count;
    }
}
//https://leetcode.com/problems/number-of-1-bits/
